@model RoomExpenseTracker.ViewModels.SummaryViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Summary"; ViewData["ActiveTab"] = "summary"; }

<div class="section-card">
  <h2>🔍 Filter by Date Range</h2>
  <form asp-controller="Expenses" asp-action="Summary" method="get">
    <div class="filter-grid">
      <div class="form-group" style="margin-bottom:0;"><label>From</label><input type="date" name="from" value="@(Model.FilterFrom.HasValue ? Model.FilterFrom.Value.ToString("yyyy-MM-dd") : "")" /></div>
      <div class="form-group" style="margin-bottom:0;"><label>To</label><input type="date" name="to" value="@(Model.FilterTo.HasValue ? Model.FilterTo.Value.ToString("yyyy-MM-dd") : "")" /></div>
      <button type="submit" style="width:auto;">Search</button>
      <a href="/Expenses/Summary" style="display:flex;align-items:center;justify-content:center;padding:11px 22px;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-weight:600;font-size:14px;text-decoration:none;color:var(--text-muted);">Show All</a>
    </div>
  </form>
</div>

<div class="summary-card">
  <h2>📊 Expense Summary @if(Model.FilterFrom.HasValue){<span style="font-size:13px;font-weight:400;opacity:0.8;">(@Model.FilterFrom.Value.ToString("dd MMM") – @Model.FilterTo.Value.ToString("dd MMM"))</span>}</h2>
  <div class="summary-grid">
    <div class="summary-item"><div class="summary-label">Grand Total</div><div class="summary-value">Rs. @Model.GrandTotal.ToString("N2")</div></div>
    <div class="summary-item"><div class="summary-label">My Total</div><div class="summary-value">Rs. @Model.MyTotal.ToString("N2")</div></div>
    <div class="summary-item"><div class="summary-label">Fair Share</div><div class="summary-value">Rs. @Model.FairShare.ToString("N2")</div></div>
    <div class="summary-item">
      <div class="summary-label">My Balance</div>
      <div class="summary-value" style="color:@(Model.MyBalance>=0?"#4ade80":"#f87171");">
        @(Model.MyBalance>=0?"+":"")Rs. @Model.MyBalance.ToString("N2")
      </div>
    </div>
    <div class="summary-item"><div class="summary-label">Total Entries</div><div class="summary-value">@Model.TotalExpenses</div></div>
    <div class="summary-item"><div class="summary-label">Active Members</div><div class="summary-value">@Model.UserSummaries.Count(u=>!u.IsAbsent)</div></div>
  </div>
</div>

<div class="section-card">
  <h2>📦 Category Breakdown</h2>
  @if (!Model.CategoryBreakdown.Any()) {
    <div class="empty-state"><span class="empty-icon">📦</span><p>No data yet.</p></div>
  } else {
    @foreach (var c in Model.CategoryBreakdown) {
      <div class="cat-bar-wrap">
        <div class="cat-bar-label"><span style="font-weight:600;">@c.Category <span style="color:var(--text-muted);font-weight:400;">(@c.Count)</span></span><span style="font-weight:600;">Rs. @c.Total.ToString("N2") <span style="color:var(--text-muted);font-weight:400;">(@c.Percentage%)</span></span></div>
        <div class="cat-bar-track"><div class="cat-bar-fill" style="width:@c.Percentage%;"></div></div>
      </div>
    }
  }
</div>

<div class="section-card">
  <h2>👥 Member Summary</h2>
  <div class="balance-table-wrap">
    <table><thead><tr><th>Member</th><th>Paid</th><th>Fair Share</th><th>Balance</th></tr></thead><tbody>
    @foreach (var u in Model.UserSummaries) {
      <tr class="@(u.Balance>=0?"balance-row-positive":"balance-row-negative")">
        <td data-label="Member"><span>@u.UserName</span> @if(u.IsAbsent){<span class="badge badge-danger" style="font-size:10px;margin-left:4px;">Absent</span>}</td>
        <td data-label="Paid">Rs. @u.Paid.ToString("N2")</td>
        <td data-label="Fair Share">Rs. @u.FairShare.ToString("N2")</td>
        <td data-label="Balance" style="font-weight:700;">@(u.Balance>=0?"+":"")Rs. @u.Balance.ToString("N2")</td>
      </tr>
    }
    </tbody></table>
  </div>
</div>

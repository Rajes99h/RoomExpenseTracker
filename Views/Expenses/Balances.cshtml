@model RoomExpenseTracker.ViewModels.SummaryViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Balances"; ViewData["ActiveTab"] = "balances"; }

<div class="section-card">
  <h2>🔍 Filter by Date Range</h2>
  <form asp-controller="Expenses" asp-action="Balances" method="get">
    <div class="filter-grid">
      <div class="form-group" style="margin-bottom:0;"><label>From</label><input type="date" name="from" value="@(Model.FilterFrom.HasValue ? Model.FilterFrom.Value.ToString("yyyy-MM-dd") : "")" /></div>
      <div class="form-group" style="margin-bottom:0;"><label>To</label><input type="date" name="to" value="@(Model.FilterTo.HasValue ? Model.FilterTo.Value.ToString("yyyy-MM-dd") : "")" /></div>
      <button type="submit" style="width:auto;">Search</button>
      <a href="/Expenses/Balances" style="display:flex;align-items:center;justify-content:center;padding:11px 22px;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-weight:600;font-size:14px;text-decoration:none;color:var(--text-muted);">Show All</a>
    </div>
  </form>
</div>

<div class="section-card">
  <h2>💸 Who Owes Whom</h2>
  @if (!Model.Settlements.Any()) {
    <div class="empty-state"><span class="empty-icon">✅</span><p>All settled up!<br/>Koi kisi ko nahi deta.</p></div>
  } else {
    @foreach (var s in Model.Settlements) {
      <div class="expense-card">
        <div>
          <div style="font-size:15px;font-weight:600;color:var(--text);">
            <strong style="color:var(--danger);">@s.From</strong>
            <span style="color:var(--text-muted);margin:0 8px;">owes</span>
            <strong style="color:var(--success);">@s.To</strong>
          </div>
          <div style="font-size:12px;color:var(--text-muted);margin-top:3px;">Payment due</div>
        </div>
        <div class="expense-amount" style="color:var(--danger);">Rs. @s.Amount.ToString("N2")</div>
      </div>
    }
  }
</div>

<div class="section-card">
  <h2>📊 Per-Person Breakdown</h2>
  <div class="balance-table-wrap">
    <table><thead><tr><th>Member</th><th>Paid</th><th>Fair Share</th><th>Balance</th></tr></thead><tbody>
    @foreach (var u in Model.UserSummaries) {
      <tr class="@(u.Balance>=0?"balance-row-positive":"balance-row-negative")">
        <td data-label="Member">@u.UserName</td>
        <td data-label="Paid">Rs. @u.Paid.ToString("N2")</td>
        <td data-label="Fair Share">Rs. @u.FairShare.ToString("N2")</td>
        <td data-label="Balance" style="font-weight:700;">@(u.Balance>=0?"+":"")Rs. @u.Balance.ToString("N2")</td>
      </tr>
    }
    </tbody></table>
  </div>
</div>

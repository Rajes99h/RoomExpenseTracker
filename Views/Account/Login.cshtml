@model RoomExpenseTracker.ViewModels.LoginViewModel
@{ Layout = "~/Views/Shared/_Layout.cshtml"; ViewData["Title"] = "Login"; }
<div id="loginWrapper">
  <div id="loginCard">
    <div class="logo-area">
      <div class="logo-glow">
        <span class="logo-star">⭐</span>
      </div>
      <h1 class="login-title">AAJ KI</h1>
      <h2 class="brand-name">Tarif</h2>
      <div class="logo-line"></div>
    </div>
    <p class="login-subtitle">Room Expenses Tracker</p>

    <form asp-controller="Account" asp-action="Login" method="post">
      @Html.AntiForgeryToken()
      @if (!ViewData.ModelState.IsValid) {
        <div class="alert alert-error" style="margin-bottom:18px;">
          @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors)) {
            <div>@e.ErrorMessage</div>
          }
        </div>
      }
      <div class="form-group">
        <label asp-for="UserId">Username</label>
        <input asp-for="UserId" placeholder="Enter your username" autocomplete="username" />
      </div>
      <div class="form-group">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" placeholder="Enter your password" autocomplete="current-password" />
      </div>
      <button type="submit" class="login-btn">Login →</button>
    </form>
  </div>
</div>

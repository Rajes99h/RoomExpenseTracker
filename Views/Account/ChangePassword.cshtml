@model RoomExpenseTracker.ViewModels.ChangePasswordViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Change Password"; ViewData["ActiveTab"] = "password"; }
<div class="section-card" style="max-width:480px;">
  <h2>🔒 Change Password</h2>
  <form asp-controller="Account" asp-action="ChangePassword" method="post">
    @Html.AntiForgeryToken()
    @if (!ViewData.ModelState.IsValid) {
      <div class="alert alert-error">
        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors)) { <div>@e.ErrorMessage</div> }
      </div>
    }
    <div class="form-group"><label>Current Password</label><input asp-for="OldPassword" placeholder="Enter current password" /></div>
    <div class="form-group"><label>New Password</label><input asp-for="NewPassword" placeholder="Minimum 4 characters" /></div>
    <div class="form-group"><label>Confirm New Password</label><input asp-for="ConfirmPassword" placeholder="Re-enter new password" /></div>
    <button type="submit" style="width:auto;">🔒 Update Password</button>
  </form>
</div>

@model RoomExpenseTracker.ViewModels.SabjiTurnViewModel
@{ Layout = "~/Views/Shared/_DashboardLayout.cshtml"; ViewData["Title"] = "Vegetables Turn"; ViewData["ActiveTab"] = "sabji"; }

<style>
.sabji-today { background: linear-gradient(135deg,#a855f7,#7c3aed) !important; color: white !important; border: none !important; }
.sabji-today .day-name, .sabji-today .user-name, .sabji-today .date-txt { color: white !important; }
.sabji-purchased { background: #ECFDF5 !important; border-color: #A7F3D0 !important; }
.sabji-card { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 12px; transition: all 0.2s; }
.sabji-card:hover { box-shadow: var(--shadow); transform: translateY(-1px); }
.day-name { font-size: 13px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
.user-name { font-size: 22px; font-weight: 700; color: var(--primary); font-family: Outfit, sans-serif; margin: 4px 0; }
.date-txt { font-size: 12px; color: var(--text-muted); }
.today-badge { background: white; color: var(--primary); padding: 2px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; display: inline-block; margin-left: 8px; }
.purchased-badge { background: #065F46; color: white; padding: 2px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; display: inline-block; }
.absent-badge { background: #FEF2F2; color: #EF4444; padding: 2px 10px; border-radius: 99px; font-size: 11px; font-weight: 700; display: inline-block; border: 1px solid #FECACA; }
</style>

<!-- TODAY HIGHLIGHT -->
@if (Model.Today != null) {
<div class="section-card" style="background:linear-gradient(135deg,#a855f7,#7c3aed);border:none;margin-bottom:20px;">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
    <div>
      <div style="color:rgba(255,255,255,0.8);font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:1px;">
        Aaj Ki Bari — @Model.Today.DayName
      </div>
      <div style="color:white;font-size:32px;font-weight:800;font-family:Outfit,sans-serif;margin:4px 0;">
        @(Model.Today.AssignedUserName ?? "Koi assign nahi")
      </div>
      <div style="color:rgba(255,255,255,0.7);font-size:13px;">
        @Model.Today.Date.ToString("dd MMMM yyyy")
        @if (Model.Today.IsPurchased) {
          <span style="background:white;color:#065F46;padding:2px 10px;border-radius:99px;font-size:11px;font-weight:700;margin-left:8px;">
            ✅ Kharidi ho gayi — @Model.Today.ActualBuyerName
          </span>
        }
      </div>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      @if (!Model.Today.IsPurchased) {
        <form asp-controller="Sabji" asp-action="MarkPurchased" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" style="background:white;color:var(--primary);font-weight:700;padding:12px 24px;border-radius:8px;font-size:15px;border:none;cursor:pointer;">
            ✅ Maine Kharidi Sabji!
          </button>
        </form>
      } else {
        <div style="background:rgba(255,255,255,0.2);color:white;padding:12px 24px;border-radius:8px;font-weight:700;">
          ✅ Aaj Ki Sabji Ho Gayi!
        </div>
      }
    </div>
  </div>
</div>
}


<!-- ADMIN — AAJ KA BUYER EDIT -->
@if (Model.IsAdmin && Model.Today != null) {
<div class="section-card" style="border:2px solid var(--primary-border);background:var(--primary-soft);">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span style="font-size:20px;">✏️</span>
    <h2 style="margin-bottom:0;color:var(--primary);">Admin — Aaj Ka Buyer Edit Karo</h2>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:end;max-width:500px;">
    <div>
      <div style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:6px;">Abhi kya dikh raha hai:</div>
      <div style="font-size:18px;font-weight:700;color:var(--primary);">
        @if (Model.Today.IsPurchased) {
          <span>✅ @Model.Today.ActualBuyerName ne kharidi</span>
        } else {
          <span style="color:var(--text-muted);">Abhi tak kisi ne nahi kharidi</span>
        }
      </div>
    </div>
    <div>
      <form asp-controller="Sabji" asp-action="UpdateBuyer" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="date" value="@Model.Today.Date.ToString("yyyy-MM-dd")" />
        <div class="form-group" style="margin-bottom:10px;">
          <label style="font-size:13px;">Kharidne wala member select karo:</label>
          <select name="userId" required style="margin-top:4px;">
            <option value="">-- Member chuno --</option>
            @foreach (var u in Model.AllUsers) {
              @if (u.UserId == Model.Today!.AssignedUserId) {
                <option value="@u.UserId" selected="selected">@u.Name</option>
              } else {
                <option value="@u.UserId">@u.Name</option>
              }
            }
          </select>
        </div>
        <button type="submit" style="width:100%;background:linear-gradient(135deg,#34D399,#10B981);color:white;font-weight:700;">
          ✅ Update Karo — Isne Kharidi Aaj
        </button>
      </form>
      @if (Model.Today.IsPurchased) {
        <form asp-controller="Sabji" asp-action="RemovePurchase" method="post" style="margin-top:8px;"
              onsubmit="return confirm('Aaj ka purchase mark hatao?')">
          @Html.AntiForgeryToken()
          <input type="hidden" name="date" value="@Model.Today.Date.ToString("yyyy-MM-dd")" />
          <button type="submit" class="btn-danger" style="width:100%;min-height:36px;font-size:13px;">
            ❌ Purchase Mark Hatao
          </button>
        </form>
      }
    </div>
  </div>
</div>
}

<!-- WEEK SCHEDULE -->
<div class="section-card">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
    <h2 style="margin-bottom:0;">Is Hafte Ka Schedule 🥬 Vegetables Turn</h2>
    @if (Model.IsAdmin) {
      <form asp-controller="Sabji" asp-action="AutoSetup" method="post" style="display:inline;">
        @Html.AntiForgeryToken()
        <button type="submit" style="width:auto;font-size:13px;padding:8px 16px;" 
                onclick="return confirm('Auto rotation set karo saare users ke liye?')">
          🔄 Auto Rotation Setup
        </button>
      </form>
    }
  </div>

  @foreach (var day in Model.WeekSchedule) {
    <div class="sabji-card @(day.IsToday ? "sabji-today" : "") @(day.IsPurchased && !day.IsToday ? "sabji-purchased" : "")">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
        <div>
          <div class="day-name">
            @day.DayName — @day.Date.ToString("dd MMM")
            @if (day.IsToday) { <span class="today-badge">Aaj</span> }
            @if (day.IsPurchased) { <span class="@(day.IsToday ? "" : "purchased-badge")">✅ Kharidi</span> }
            @if (day.IsAbsent && !day.IsPurchased) { <span class="absent-badge">Absent (Next wale ki bari)</span> }
          </div>
          <div class="user-name">@(day.AssignedUserName ?? "—")</div>
          @if (day.IsPurchased && day.ActualBuyerName != null) {
            <div class="date-txt">Kharida: @day.ActualBuyerName ne</div>
          }
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          @if (day.IsToday && !day.IsPurchased) {
            <form asp-controller="Sabji" asp-action="MarkPurchased" method="post" style="display:inline;">
              @Html.AntiForgeryToken()
              <button type="submit" style="width:auto;font-size:13px;padding:8px 16px;background:white;color:var(--primary);">
                ✅ Maine Kharidi
              </button>
            </form>
          }
          @if (Model.IsAdmin) {
            <form asp-controller="Sabji" asp-action="AssignTurn" method="post" 
                  style="display:flex;gap:6px;align-items:center;">
              @Html.AntiForgeryToken()
              <input type="hidden" name="dayOfWeek" value="@((int)day.Date.DayOfWeek)" />
              <select name="userId" style="padding:6px 10px;font-size:13px;width:auto;min-width:120px;">
                <option value="">-- Select --</option>
                @foreach (var u in Model.AllUsers) {
                  @if (u.UserId == day.AssignedUserId) {
                    <option value="@u.UserId" selected="selected">@u.Name</option>
                  } else {
                    <option value="@u.UserId">@u.Name</option>
                  }
                }
              </select>
              <button type="submit" style="width:auto;font-size:12px;padding:6px 12px;">
                Save
              </button>
            </form>
          }
        </div>
      </div>
    </div>
  }
</div>

